#Singly linked lists

class SinglyNode:
    
    def __init__(self, val, next=None):
        self.val = val
        self.next = next
    
    def __str__(self):
        return str(self.val)
        
#Adding nodes
Head = SinglyNode(1)
A= SinglyNode(2)
B= SinglyNode(3)
C= SinglyNode(4)

Head.next = A
A.next = B
B.next = C

# print(Head)


#Traversing the list - O(n)
curr = Head
while curr:
    print(curr)
    curr = curr.next
    
#Display linked list
def display(head):
    curr= head
    elements=[]
    while curr:
        elements.append(str(curr.val))
        curr= curr.next
    print('->'.join(elements))
    
#1-> 2-> 3-> 4


def search(head, val):
    curr= head
    while curr:
        if val == curr.val:
            return True
        curr = curr.next
    return False

search(head,2)
