#Implementing graph with class
class Node:
    def __init__(self, value):
        self.value = value
        self.neighbors = []
        
    def __str__(self):
        return f'Node({self.value})'
    
    def display(self):
        connections = [node.value for node in self.neighbors]
        return f'{self.value} is connected to: {connections}'
        
