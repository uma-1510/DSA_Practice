#DFS with a recursion - O(V+E) where V is the number of nodes and E is the number if edges
dfs_recursive(node):
    print(node) #output the node
    for neighbor in D[node]:
        if neighbour not in seen:
            seen.add(neighbour)
            dfs_recursive(neighbour)
    
